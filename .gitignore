# ===========================================
# CREDENCIALES Y SECRETOS - NUNCA SUBIR
# ===========================================
# Configuracion de la app con la API key de OpenAI
app/config.php

# Credenciales AWS (no deberian estar aqui pero por seguridad)
**/credentials
*.pem
*.key

# Variables de entorno locales
.env
.env.local
.env.*.local


# ===========================================
# TERRAFORM
# ===========================================
# Estado de Terraform: contiene info sensible (passwords en plano, IDs, etc.)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plugins descargados (pesan MB y son regenerables con terraform init)
.terraform/

# Archivos de configuracion local con valores especificos del usuario
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# Logs de Terraform
crash.log
crash.*.log


# ===========================================
# IDE Y EDITORES
# ===========================================
.vscode/
.idea/
*.swp
*.swo
*~


# ===========================================
# SISTEMA OPERATIVO
# ===========================================
# Windows
Thumbs.db
Desktop.ini
desktop.ini

# macOS
.DS_Store
__MACOSX/


# ===========================================
# PHP / DEPENDENCIAS
# ===========================================
vendor/
composer.lock


# ===========================================
# ARCHIVOS TEMPORALES Y BACKUPS
# ===========================================
*.bak
*.tmp
*.log
*~
